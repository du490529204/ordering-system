<view class="container">

<!-- 搜索框 -->
<view class="search-box">
  <input placeholder="输入商品名称搜索" bindinput="onSearch" value="{{keywords}}" />
</view>

<!-- 主体：左侧竖向tab + 右侧商品列表 -->
<view class="main-box">
  <!-- 竖向价格选项卡 -->
  <view class="tab-vertical">
    <text class="tab {{activeTab===0?'active':''}}" bindtap="switchTab" data-index="0">全部</text>
    <text wx:for="{{priceTabs}}" wx:key="index"
      class="tab {{activeTab===index+1?'active':''}}"
      bindtap="switchTab" data-index="{{index+1}}">
      {{item}}
    </text>
  </view>

  <!-- 右侧商品列表 -->
  <scroll-view class="goods-scroll" scroll-y>
    <view class="goods-list">
      <block wx:for="{{showList}}" wx:key="id">
        <view class="goods-item flex-row">
          <image src="{{item.goods_img||'/images/default.png'}}" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="name">{{item.goods_name}}</text>
            <text class="attr">属性：{{item.goods_attr||'无'}}</text>
            <text class="price">售价：¥{{item.price}}</text>
            <text class="stock {{item.stock<=0?'red':''}}">库存：{{item.stock}}</text>
          </view>
          <button wx:if="{{item.stock<=0}}" size="mini" type="primary" bindtap="goOrder" data-item="{{item}}">补货</button>
        </view>
      </block>
    </view>
  </scroll-view>
</view>

</view>